# Supabase public client settings
NEXT_PUBLIC_SUPABASE_URL=https://xyzcompany.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# Supabase service role key (server only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT secrets for access and refresh token signing
JWT_ACCESS_TOKEN_SECRET=change-this-to-a-strong-secret
JWT_REFRESH_TOKEN_SECRET=change-this-to-a-second-strong-secret
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_IN=7d
PASSWORD_RESET_TOKEN_EXPIRES_IN=1h

# Application settings
NEXT_PUBLIC_APP_NAME=Progetto GPOI

# Worker / cron collection
DATABASE_URL=postgres://<user>:<password>@<host>:<port>/<database>
COLLECT_SYMBOLS=BTC,ETH,BNB,ADA,SOL,DOGE,LINK,UNI,ATOM,XRP,LTC,MATIC,DOT,AVAX,SHIB
COLLECT_CRON=*/15 * * * *
MAX_REQUESTS_PER_MINUTE=5
